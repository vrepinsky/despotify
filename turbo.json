{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["API_*", "DB_*", "LOG_LEVEL", "VITE_*", "WEB_PORT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "check": {
      "dependsOn": ["typecheck", "lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^typecheck"]
    }
  }
}
